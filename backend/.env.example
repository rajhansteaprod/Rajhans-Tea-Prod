# ============================================
# RND ECOMMERCE — Environment Variables
# Copy to .env and fill in values
# ============================================

# ─── Core ────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ─────────────────────────────────
MONGO_URI=mongodb://localhost:27017/rnd-ecommerce
MONGO_TEST_URI=mongodb://localhost:27018/rnd-ecommerce-test

# ─── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ─── Firebase ────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Razorpay ────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=

# ─── Email (SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RnD <noreply@rnd.com>

# ─── SMS (MSG91) ─────────────────────────────
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=RAJHNS

# ─── Shipping (Shiprocket) ───────────────────
SHIPPING_PROVIDER=shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_TOKEN=

# ─── Rate Limiting ───────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# ─── Logging ─────────────────────────────────
LOG_LEVEL=debug
