FROM node:22-alpine

WORKDIR /app

# Copy root workspace files
COPY package.json package-lock.json* ./
COPY backend/package.json ./backend/

RUN npm install

COPY backend/ ./backend/
COPY tsconfig.base.json ./

# Install tsconfig-paths for alias resolution
RUN npm install tsconfig-paths --workspace=backend

WORKDIR /app/backend

EXPOSE 3000

CMD ["npx", "nodemon"]
