{
  "info": {
    "name": "RnD Ecommerce — Device Tracking & Session Management",
    "description": "Manual test collection for TC-001 through TC-012. Run in order. Set ACCESS_TOKEN and ADMIN_TOKEN variables after TC-000 Login calls.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:3100/api/v1" },
    { "key": "ACCESS_TOKEN",  "value": "" },
    { "key": "ADMIN_TOKEN",   "value": "" },
    { "key": "SESSION_ID",    "value": "" },
    { "key": "ADMIN_USER_ID", "value": "69b86b091d885c1ef049dcab" },
    { "key": "CUSTOMER1_ID",  "value": "69b871cd936a8729624cc6e5" },
    { "key": "CUSTOMER2_ID",  "value": "69b87325936a8729624cc6e5" }
  ],
  "item": [
    {
      "name": "0 — Setup: Login (Customer)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success && res.data && res.data.accessToken) {",
              "  pm.collectionVariables.set('ACCESS_TOKEN', res.data.accessToken);",
              "  pm.test('Login succeeded — ACCESS_TOKEN saved', () => pm.expect(res.success).to.be.true);",
              "} else {",
              "  pm.test('Login response shape', () => {",
              "    console.warn('Paste a real Firebase idToken into the request body');",
              "    pm.expect(res).to.have.property('success');",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/verify-token",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idToken\": \"<PASTE_CUSTOMER_FIREBASE_ID_TOKEN_HERE>\"\n}"
        },
        "description": "Login as a customer. Copy the accessToken from the response and it will be auto-saved into ACCESS_TOKEN collection variable."
      }
    },
    {
      "name": "0 — Setup: Login (Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success && res.data && res.data.accessToken) {",
              "  pm.collectionVariables.set('ADMIN_TOKEN', res.data.accessToken);",
              "  pm.test('Admin login succeeded — ADMIN_TOKEN saved', () => pm.expect(res.success).to.be.true);",
              "} else {",
              "  pm.test('Admin login response shape', () => {",
              "    console.warn('Paste a real Firebase idToken for admin into the request body');",
              "    pm.expect(res).to.have.property('success');",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/verify-token",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idToken\": \"<PASTE_ADMIN_FIREBASE_ID_TOKEN_HERE>\"\n}"
        },
        "description": "Login as admin (phone 6266303713). ADMIN_TOKEN saved automatically."
      }
    },
    {
      "name": "TC-002 — List own sessions (user)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('success: true', () => pm.expect(res.success).to.be.true);",
              "pm.test('data is array', () => pm.expect(res.data).to.be.an('array'));",
              "",
              "if (res.data.length > 0) {",
              "  const s = res.data[0];",
              "  pm.test('ip ends in .xxx (masked)', () => pm.expect(s.ip).to.match(/\\.xxx$/));",
              "  pm.test('no fullIp exposed', () => pm.expect(s).to.not.have.property('fullIp'));",
              "  pm.test('no userAgent exposed', () => pm.expect(s).to.not.have.property('userAgent'));",
              "  pm.test('has deviceName', () => pm.expect(s.deviceName).to.be.a('string'));",
              "  const currentSessions = res.data.filter(x => x.isCurrent);",
              "  pm.test('at most one isCurrent session', () => pm.expect(currentSessions.length).to.be.lte(1));",
              "",
              "  // Save first non-current session ID for TC-004",
              "  const nonCurrent = res.data.find(x => !x.isCurrent);",
              "  if (nonCurrent) pm.collectionVariables.set('SESSION_ID', nonCurrent._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
        "url": "{{baseUrl}}/auth/sessions",
        "description": "List own sessions. IP should be masked (ends in .xxx). No fullIp or userAgent fields."
      }
    },
    {
      "name": "TC-003 — isCurrent flag on own session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "const current = res.data.filter(s => s.isCurrent);",
              "pm.test('Exactly one isCurrent session', () => pm.expect(current.length).to.equal(1));",
              "pm.test('Current session has correct fields', () => {",
              "  pm.expect(current[0]).to.have.property('deviceName');",
              "  pm.expect(current[0]).to.have.property('browser');",
              "  pm.expect(current[0]).to.have.property('os');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
        "url": "{{baseUrl}}/auth/sessions",
        "description": "Same endpoint as TC-002. Since ACCESS_TOKEN was set from a fresh login, exactly 1 session should be isCurrent."
      }
    },
    {
      "name": "TC-004 — Revoke a non-current session (user)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const sid = pm.collectionVariables.get('SESSION_ID');",
              "if (!sid) console.warn('SESSION_ID not set — run TC-002 first or set it manually');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 204 No Content', () => pm.response.to.have.status(204));",
              "pm.test('Empty body', () => pm.expect(pm.response.text()).to.equal(''));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
        "url": "{{baseUrl}}/auth/sessions/{{SESSION_ID}}",
        "description": "Revoke a specific session by ID. SESSION_ID is auto-populated from TC-002 (first non-current session). Returns 204."
      }
    },
    {
      "name": "TC-005 — Cannot revoke another user's session (403)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// You need a session ID belonging to a DIFFERENT user.",
              "// After running TC-007, grab one of those session IDs and paste below.",
              "// Or hardcode a known seeded session ID here for quick testing."
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 403 Forbidden', () => pm.response.to.have.status(403));",
              "const res = pm.response.json();",
              "pm.test('success: false', () => pm.expect(res.success).to.be.false);",
              "pm.test('message mentions own sessions', () => pm.expect(res.message).to.include('own'));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
        "url": "{{baseUrl}}/auth/sessions/<PASTE_OTHER_USERS_SESSION_ID_HERE>",
        "description": "Attempt to revoke a session belonging to a different user. Should return 403 with 'You can only revoke your own sessions'."
      }
    },
    {
      "name": "TC-006 — Invalid session ID format (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 400 Bad Request', () => pm.response.to.have.status(400));",
              "const res = pm.response.json();",
              "pm.test('success: false', () => pm.expect(res.success).to.be.false);",
              "pm.test('Validation failed message', () => pm.expect(res.message).to.include('Validation'));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
        "url": "{{baseUrl}}/auth/sessions/not-a-valid-id",
        "description": "Pass a non-ObjectId string as the session ID. Zod validator should reject with 400."
      }
    },
    {
      "name": "TC-007 — Admin: list sessions for Customer 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('success: true', () => pm.expect(res.success).to.be.true);",
              "pm.test('data is array', () => pm.expect(res.data).to.be.an('array'));",
              "",
              "if (res.data.length > 0) {",
              "  const s = res.data[0];",
              "  pm.test('fullIp present (unmasked)', () => pm.expect(s.fullIp).to.be.a('string'));",
              "  pm.test('userAgent present (raw UA)', () => pm.expect(s.userAgent).to.be.a('string'));",
              "  pm.test('userId present', () => pm.expect(s.userId).to.be.a('string'));",
              "  pm.test('ip still masked in ip field', () => pm.expect(s.ip).to.match(/\\.xxx$/));",
              "",
              "  // Save a session ID for TC-008",
              "  pm.collectionVariables.set('SESSION_ID', res.data[0]._id);",
              "  console.log('Saved SESSION_ID for TC-008:', res.data[0]._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/users/{{CUSTOMER1_ID}}/sessions",
        "description": "Admin lists all sessions for Customer 1 (69b871cd936a8729624cc6e5). Should see fullIp, userAgent, userId. SESSION_ID auto-saved for TC-008."
      }
    },
    {
      "name": "TC-008 — Admin: revoke a specific session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('success: true', () => pm.expect(res.success).to.be.true);",
              "pm.test('data has userId', () => pm.expect(res.data).to.have.property('userId'));",
              "pm.test('data has deviceName', () => pm.expect(res.data).to.have.property('deviceName'));",
              "pm.test('message mentions Session revoked', () => pm.expect(res.message).to.include('Session revoked'));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/sessions/{{SESSION_ID}}",
        "description": "Admin revokes the session saved from TC-007. Returns 200 with { userId, deviceName }."
      }
    },
    {
      "name": "TC-008b — Verify session was removed",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('success: true', () => pm.expect(res.success).to.be.true);",
              "console.log('Remaining sessions for Customer 1:', res.data.length);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/users/{{CUSTOMER1_ID}}/sessions",
        "description": "Verify session count for Customer 1 decreased by 1 after TC-008."
      }
    },
    {
      "name": "TC-009 — Admin: force-logout ALL sessions for Customer 2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 204 No Content', () => pm.response.to.have.status(204));",
              "pm.test('Empty body', () => pm.expect(pm.response.text()).to.equal(''));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/users/{{CUSTOMER2_ID}}/sessions",
        "description": "Nuke ALL sessions for Customer 2 (69b87325936a8729624cc6e5). Returns 204."
      }
    },
    {
      "name": "TC-009b — Verify Customer 2 has zero sessions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('data is empty array', () => pm.expect(res.data).to.be.an('array').with.lengthOf(0));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/users/{{CUSTOMER2_ID}}/sessions",
        "description": "Follow-up check — Customer 2 should have 0 sessions after TC-009."
      }
    },
    {
      "name": "TC-010 — Token refresh updates lastUsedAt",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('success: true', () => pm.expect(res.success).to.be.true);",
              "pm.test('has new accessToken', () => pm.expect(res.data.accessToken).to.be.a('string'));",
              "// New token → update collection variable",
              "if (res.data.accessToken) pm.collectionVariables.set('ACCESS_TOKEN', res.data.accessToken);",
              "console.log('Token refreshed. Run TC-002 again to see updated lastUsedAt.');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/refresh-token",
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "description": "Trigger token rotation. Requires the refreshToken httpOnly cookie (set automatically by the Login call). New ACCESS_TOKEN saved. Then run TC-002 to see fresh lastUsedAt."
      }
    },
    {
      "name": "TC-011 — Non-admin blocked from admin endpoints (403)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 403 Forbidden', () => pm.response.to.have.status(403));",
              "const res = pm.response.json();",
              "pm.test('success: false', () => pm.expect(res.success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/users/{{CUSTOMER1_ID}}/sessions",
        "description": "Use the CUSTOMER ACCESS_TOKEN (not admin) to hit an admin endpoint. Should return 403."
      }
    },
    {
      "name": "TC-012 — Unauthenticated request blocked (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 401 Unauthorized', () => pm.response.to.have.status(401));",
              "const res = pm.response.json();",
              "pm.test('success: false', () => pm.expect(res.success).to.be.false);",
              "pm.test('message is Access token required', () => pm.expect(res.message).to.equal('Access token required'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/auth/sessions",
        "description": "No Authorization header. Should return 401 with 'Access token required'."
      }
    },
    {
      "name": "TC-007b — Admin: list sessions for Admin user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('success: true', () => pm.expect(res.success).to.be.true);",
              "console.log('Admin sessions count:', res.data.length);",
              "if (res.data.length > 0) {",
              "  const s = res.data[0];",
              "  console.log('First session:', JSON.stringify(s, null, 2));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
        "url": "{{baseUrl}}/admin/users/{{ADMIN_USER_ID}}/sessions",
        "description": "Admin views their own sessions from the admin endpoint (userId = 69b86b091d885c1ef049dcab). Should see 2 seeded sessions."
      }
    }
  ]
}
